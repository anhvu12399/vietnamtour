  "section.brand-client-feedback-testimonial": [
    {
      "tag": "h2",
      "class": "brand-client-feedback-testimonial__title",
      "id": "",
      "text": "Moments\u00a0we\u2019ve\u00a0created"
    },
    {
      "tag": "span",
      "class": "",
      "id": "",
      "text": "\u201cWe have a particular picture of Nona in that park, looking so peaceful.\u201d"
    },
    {
      "tag": "span",
      "class": "",
      "id": "",
      "text": "\u201cIt was in the smaller moments that the city demanded my attention most. The green-and-yellow rickshaws, the cows placidly wandering the streets.\u201d"
    },
    {
      "tag": "span",
      "class": "",
      "id": "",
      "text": "\u201cThe feeling you get from being in the village where your grandparents were raised is unbelievable.\u201d"
    },
    {
      "tag": "span",
      "class": "",
      "id": "",
      "text": "\u201cWatching my child\u2019s eyes, when they see something spectacular,\u00a0I\u2019ve\u00a0got to experience that\u00a0over and over.\u201d"
    },
    {
      "tag": "span",
      "class": "",
      "id": "",
      "text": "\u201cOur eyes were darting everywhere. It was like the moment had been stage-managed.\u201d"
    },
    {
      "tag": "span",
      "class": "",
      "id": "",
      "text": "\u201cWe have a particular picture of Nona in that park, looking so peaceful.\u201d"
    },
    {
